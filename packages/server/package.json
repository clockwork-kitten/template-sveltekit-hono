{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "check": "bun run check:types && bun run check:knip && bun run check:lint && bun audit",
    "check:types": "tsc --noEmit",
    "check:knip": "knip",
    "check:lint": "eslint src",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "pino": "^9.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@josephcarey/eslint-config": "workspace:../../../shared/eslint",
    "@josephcarey/tsconfig": "workspace:../../../shared/tsconfig",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-depend": "^0.11.0",
    "eslint-plugin-perfectionist": "^4.0.0",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-unicorn": "^57.0.0",
    "knip": "^5.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
